# Revolut Merchant API Configuration
# Get your keys from: https://sandbox-business.revolut.com → APIs → Merchant API

# Sandbox API base URL (change to https://merchant.revolut.com for production)
REVOLUT_API_URL=https://sandbox-merchant.revolut.com

# Your Revolut Merchant API Public Key (used on the client side)
REVOLUT_API_PUBLIC_KEY=pk_your_public_key_here

# Your Revolut Merchant API Secret Key (used on the server side)
REVOLUT_API_SECRET_KEY=sk_your_secret_key_here

# Your Revolut Webhook Signing Secret (for verifying webhook payloads)
REVOLUT_WEBHOOK_SECRET=your_webhook_secret_here

# Environment: sandbox or prod
REVOLUT_ENVIRONMENT=sandbox

# Server port (for PHP built-in server)
SERVER_PORT=8080
